# Switch to R 


####################################################################################################
# plot_stability_by_miRNA_targets.R
#
# Language: R
#
# Aim:
#   Compare transcript stability between genes with and without predicted miRNA target sites.
#
# Input:
#   targets_<miRNA>_<strand>_<kmer>.txt # output from running the miRNA searches
#   Totalcounts_norm.tsv # stability values # PRO-seq over mRNA-seq ratios)
#   VectorBase-60_AaegyptiLVP_AGWG.gff # gff file
#
# Output:
#   eCDF plots of MminP grouped by strongest miRNA target class (8mer > 7mer > 6mer > none)
#   Genes with both high- and low-abundance miRNA target sites are counted as high
#
####################################################################################################

# Load libraries
library(dplyr)
library(ggplot2)
library(tidyr)
library(purrr)
library(rtracklayer)
library(tibble)

# Directories and file locations
stability_dir <- "../Stability"
miRNA_dir <- "../stability/miRNA"
gff_file <- "VectorBase-60_AaegyptiLVP_AGWG.gff"
setwd(miRNA_dir)



# Specify miRNAs
# For highest and lowest 3 miRNAs
miRNAs <- c("aae-miR-2940-3p", "aae-miR-184", "aae-bantam-3p",
            "aae-miR-929", "aae-miR-316", "aae-miR-932-5p")
# Into the 2 groups
high_miRNAs <- c("aae-miR-2940-3p", "aae-miR-184", "aae-bantam-3p")
low_miRNAs <- c("aae-miR-929", "aae-miR-316", "aae-miR-932-5p")

# kmers
kmers <- c("6mer", "7mer", "8mer")



# Settings for filtering and visualisation
# genes with both HIGH and LOW hits are counted as HIGH 
collapse_both_to_high <- TRUE

# filtering for minimal coverage
keep_only_protein_coding <- TRUE
min_p_avg <- 1
min_m_avg <- 1

# bootstrap to 1000 for ecdf confidence/ribbons
set.seed(1)
B <- 1000
grid_n <- 300

# colors 
kmer_cols <- c(
  "none" = "blue",
  "6mer" = "#8da0cb",
  "7mer" = "#fc8d62",
  "8mer" = "#66c2a5"
)

#################################################
# Function to process the miRNA target hits
#################################################

read_mirna_targets <- function(miRNA, kmer) {
  
  plus_file  <- paste0("targets_", miRNA, "_plus_",  kmer, ".txt")
  minus_file <- paste0("targets_", miRNA, "_minus_", kmer, ".txt")
  
  target_plus  <- read.delim(plus_file, header = TRUE, stringsAsFactors = FALSE)
  target_minus <- read.delim(minus_file, header = TRUE, stringsAsFactors = FALSE)
  
  bind_rows(target_plus, target_minus) %>%
    mutate(
      genenamefull = trimws(as.character(genenamefull)),
      target_position = suppressWarnings(as.numeric(target_position))
    ) %>%
    filter(!is.na(genenamefull), genenamefull != "") %>%
    filter(!is.na(target_position), target_position >= 0) %>%
    distinct(genenamefull, .keep_all = TRUE) %>%
    transmute(
      gene = genenamefull,
      miRNA = miRNA,
      kmer = kmer,
      target_position = target_position
    )
}



# Loading in all the target files

all_targets_long <- expand.grid(miRNA = miRNAs, kmer = kmers, stringsAsFactors = FALSE) %>%
  split(seq_len(nrow(.))) %>%
  map_dfr(~ read_mirna_targets(.x$miRNA, .x$kmer)) %>%
  mutate(
    category = case_when(
      miRNA %in% high_miRNAs ~ "high",
      miRNA %in% low_miRNAs ~ "low",
      TRUE ~ NA_character_
    ),
    kmer_rank = case_when(
      kmer == "6mer" ~ 1L,
      kmer == "7mer" ~ 2L,
      kmer == "8mer" ~ 3L
    )
  )



# Loading in the stability scores and gff/annotation file

Totalcounts_norm <- read.table(
  file.path(stability_dir, "Totalcounts_norm.tsv"),
  header = TRUE, sep = "\t", stringsAsFactors = FALSE
)

gff_annot <- rtracklayer::import(gff_file) %>%
  as.data.frame() %>%
  tibble::as_tibble()

total_annot <- Totalcounts_norm %>%
  left_join(gff_annot %>% select(ID, type), by = c("gene" = "ID"))



# Assignment of targets/hits to strongest class (8mer > 7mer > 6mer)

gene_target_summary <- all_targets_long %>%
  group_by(gene, category) %>%
  summarise(
    strongest_kmer_rank = max(kmer_rank),
    .groups = "drop"
  ) %>%
  mutate(
    strongest_kmer = case_when(
      strongest_kmer_rank == 3L ~ "8mer",
      strongest_kmer_rank == 2L ~ "7mer",
      strongest_kmer_rank == 1L ~ "6mer",
      TRUE ~ "none"
    )
  ) %>%
  select(-strongest_kmer_rank) %>%
  pivot_wider(
    names_from = category,
    values_from = strongest_kmer,
    names_prefix = "strongest_"
  )

mirna_targets_df <- total_annot %>%
  left_join(gene_target_summary, by = "gene") %>%
  mutate(
    strongest_high = ifelse(is.na(strongest_high), "none", strongest_high),
    strongest_low  = ifelse(is.na(strongest_low),  "none", strongest_low),
    strongest_high = factor(strongest_high, levels = c("none", "6mer", "7mer", "8mer")),
    strongest_low  = factor(strongest_low,  levels = c("none", "6mer", "7mer", "8mer"))
  )


# Define the groups
mirna_targets_df <- mirna_targets_df %>%
  mutate(
    target_group_raw = case_when(
      strongest_high != "none" & strongest_low != "none" ~ "both",
      strongest_high != "none" ~ "high_only",
      strongest_low  != "none" ~ "low_only",
      TRUE ~ "none"
    )
  )

# collapsed grouping: both -> high
if (collapse_both_to_high) {
  mirna_targets_df <- mirna_targets_df %>%
    mutate(
      target_group_collapsed = case_when(
        strongest_high != "none" ~ "high",
        strongest_low  != "none" ~ "low",
        TRUE ~ "none"
      )
    )
} else {
  mirna_targets_df <- mirna_targets_df %>%
    mutate(
      target_group_collapsed = case_when(
        target_group_raw == "both" ~ "both",
        target_group_raw == "high_only" ~ "high",
        target_group_raw == "low_only" ~ "low",
        TRUE ~ "none"
      )
    )
}


# Only plot stability scores for protein_coding and minimal coverage 

mirna_targets_df_filtered <- mirna_targets_df

if (keep_only_protein_coding) {
  mirna_targets_df_filtered <- mirna_targets_df_filtered %>%
    filter(type == "protein_coding_gene")
}

mirna_targets_df_filtered <- mirna_targets_df_filtered %>%
  filter(p_avg > min_p_avg, m_avg > min_m_avg)


#####################################################
# Function: dataframe for ecdf + ribbons
#####################################################

make_ecdf_ci_df <- function(df, group_var, value_var = "MminP", B = 1000, grid_n = 300) {
  
  groups <- levels(df[[group_var]])
  ci_list <- list()
  
  for (g in groups) {
    x <- sort(df[[value_var]][df[[group_var]] == g])
    if (length(x) < 2) next
    
    grid_x <- seq(min(x), max(x), length.out = grid_n)
    Fhat <- stats::ecdf(x)(grid_x)
    
    boot_mat <- replicate(B, {
      xb <- sample(x, replace = TRUE)
      stats::ecdf(xb)(grid_x)
    })
    
    lo <- apply(boot_mat, 1, quantile, probs = 0.025)
    hi <- apply(boot_mat, 1, quantile, probs = 0.975)
    
    ci_list[[g]] <- data.frame(
      MminP = grid_x,
      ecdf = Fhat,
      lo = lo,
      hi = hi,
      group = g
    )
  }
  
  ci_df <- do.call(rbind, ci_list)
  ci_df$group <- factor(ci_df$group, levels = groups)
  ci_df
}


#####################################################
# Plotting distribution of stability scores for miRNA targets of top3 expressed miRNAs, separated by kmer
#####################################################

# So for the HIGH miRNA targets, the eCDF + ribbons for none / 6mer / 7mer / 8mer groups

plot_high_df <- mirna_targets_df_filtered %>%
  mutate(group = factor(strongest_high, levels = c("none", "6mer", "7mer", "8mer")))

n_tbl_high <- plot_high_df %>% count(group, name = "n")
print(n_tbl_high)

ci_df_high <- make_ecdf_ci_df(plot_high_df, group_var = "group", value_var = "MminP",
                              B = B, grid_n = grid_n)

lab_map_high <- setNames(
  paste0(n_tbl_high$group, " (n=", n_tbl_high$n, ")"),
  n_tbl_high$group
)

p_ecdf_high <- ggplot(ci_df_high, aes(MminP, ecdf, color = group, fill = group)) +
  geom_ribbon(aes(ymin = lo, ymax = hi), alpha = 0.15, color = NA) +
  geom_step(linewidth = 1) +
  scale_color_manual(values = kmer_cols, breaks = names(lab_map_high), labels = lab_map_high, drop = FALSE) +
  scale_fill_manual(values = kmer_cols, breaks = names(lab_map_high), labels = lab_map_high, drop = FALSE) +
  coord_cartesian(ylim = c(0, 1), expand = FALSE) +
  labs(
    title = "eCDF of MminP by strongest HIGH-miRNA target class",
    subtitle = "Genes with both HIGH and LOW hits are counted in HIGH",
    x = "MminP", y = "eCDF", color = "Group", fill = "Group"
  ) +
  theme_classic() +
  scale_x_continuous(breaks = seq(-8, 8, 2))

print(p_ecdf_high)



# Same but then for LOW miRNAs (lowest 3 expressed miRNAs in Aag2)

plot_low_df <- mirna_targets_df_filtered %>%
  mutate(group = factor(strongest_low, levels = c("none", "6mer", "7mer", "8mer")))

n_tbl_low <- plot_low_df %>% count(group, name = "n")
print(n_tbl_low)

ci_df_low <- make_ecdf_ci_df(plot_low_df, group_var = "group", value_var = "MminP",
                             B = B, grid_n = grid_n)

lab_map_low <- setNames(
  paste0(n_tbl_low$group, " (n=", n_tbl_low$n, ")"),
