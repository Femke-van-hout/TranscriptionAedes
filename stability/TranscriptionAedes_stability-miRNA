####################################################################################################
# run_mirna_target_search.sh
#
# Language: Bash / Unix
#
# Aim:
#   Search Aedes aegypti UTR FASTA files for exact miRNA seed target matches.
#
# Input, 3' UTRs extracted from gff file (AaegL5 version 3)
#   UTRs_plus.fa
#   UTRs_minus.fa
#
# Arguments:
#   1. miRNA name
#   2. target motif sequence
#   3. strand: plus or minus
#   4. kmer class: 6mer, 7mer, or 8mer
#
# Output:
#   targets_<miRNA>_<strand>_<kmer>.txt
####################################################################################################


#!/bin/bash -l
#$ -S /bin/bash
#$ -cwd
#$ -V
#$ -pe smp 1

set -euo pipefail

# directory 
WORKDIR="/home/femkevh/PROseqAag2/stability/miRNA"
cd "$WORKDIR"

# fasta files for UTR sequences
FASTA_PLUS="$WORKDIR/UTRs_plus.fa"
FASTA_MINUS="$WORKDIR/UTRs_minus.fa"

# parameters for miRNA target search: miRNA name, target sequence, strand, kmer
MIRNA="${1:?Usage: $0 <mirna> <motif> <plus|minus> <6mer|7mer|8mer>}"
MOTIF="${2:?Usage: $0 <mirna> <motif> <plus|minus> <6mer|7mer|8mer>}"
STRAND="${3:?Usage: $0 <mirna> <motif> <plus|minus> <6mer|7mer|8mer>}"
KMER="${4:?Usage: $0 <mirna> <motif> <plus|minus> <6mer|7mer|8mer>}"

echo "Running: $MIRNA | $STRAND | $KMER | motif=$MOTIF"

if [[ "$STRAND" == "plus" ]]; then
    FASTA="$FASTA_PLUS"
elif [[ "$STRAND" == "minus" ]]; then
    FASTA="$FASTA_MINUS"
else
    echo "ERROR: STRAND must be plus or minus" >&2
    exit 1
fi

OUTPUT_FILE="targets_${MIRNA}_${STRAND}_${KMER}.txt"
echo -e "genenamefull\ttarget_position" > "$OUTPUT_FILE"

genenamefull=""

# header line with > to substract genename and then next line is the actual sequence

while IFS= read -r line; do
    if [[ "$line" =~ ^\> ]]; then
        genenamefull="${line#>}"
    else
        echo "$line" | grep -b -o "$MOTIF" | \
        awk -F: -v gene="$genenamefull" 'BEGIN{OFS="\t"} {print gene, $1}' >> "$OUTPUT_FILE" || true
    fi
done < "$FASTA"


########################################################################################################################################
#											Running the miRNA searches
########################################################################################################################################

# Example for running all aae-miR-2940-3p searches
	# Searching for the 6mer/7mer/8mer matches, the plus and minus hits are later merged again

qsub -N aae-miR-2940-3p_plus_6mer  -e aae-miR-2940-3p_plus_6mer.err.txt  -o aae-miR-2940-3p_plus_6mer.out.txt  run_mirna_target_search.sh aae-miR-2940-3p TGTCGA plus 6mer
qsub -N aae-miR-2940-3p_minus_6mer -e aae-miR-2940-3p_minus_6mer.err.txt -o aae-miR-2940-3p_minus_6mer.out.txt run_mirna_target_search.sh aae-miR-2940-3p TCGACA minus 6mer
qsub -N aae-miR-2940-3p_plus_7mer  -e aae-miR-2940-3p_plus_7mer.err.txt  -o aae-miR-2940-3p_plus_7mer.out.txt  run_mirna_target_search.sh aae-miR-2940-3p CTGTCGA plus 7mer
qsub -N aae-miR-2940-3p_minus_7mer -e aae-miR-2940-3p_minus_7mer.err.txt -o aae-miR-2940-3p_minus_7mer.out.txt run_mirna_target_search.sh aae-miR-2940-3p TCGACAG minus 7mer
qsub -N aae-miR-2940-3p_plus_8mer  -e aae-miR-2940-3p_plus_8mer.err.txt  -o aae-miR-2940-3p_plus_8mer.out.txt  run_mirna_target_search.sh aae-miR-2940-3p CTGTCGAA plus 8mer
qsub -N aae-miR-2940-3p_minus_8mer -e aae-miR-2940-3p_minus_8mer.err.txt -o aae-miR-2940-3p_minus_8mer.out.txt run_mirna_target_search.sh aae-miR-2940-3p TTCGACAG minus 8mer

