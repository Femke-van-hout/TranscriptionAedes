p_ecdf_low <- ggplot(ci_df_low, aes(MminP, ecdf, color = group, fill = group)) +
  geom_ribbon(aes(ymin = lo, ymax = hi), alpha = 0.15, color = NA) +
  geom_step(linewidth = 1) +
  scale_color_manual(values = kmer_cols, breaks = names(lab_map_low), labels = lab_map_low, drop = FALSE) +
  scale_fill_manual(values = kmer_cols, breaks = names(lab_map_low), labels = lab_map_low, drop = FALSE) +
  coord_cartesian(ylim = c(0, 1), expand = FALSE) +
  labs(
    title = "eCDF of MminP by strongest LOW-miRNA target class",
